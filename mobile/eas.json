{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": { "simulator": false },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://fitfriends.replit.app"
      }
    },
    "preview": {
      "distribution": "store",
      "ios": { "simulator": false },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://fitfriends.replit.app"
      }
    },
    "production": {
      "distribution": "store",
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://fitfriends.replit.app"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
